---
layout: default
---

<article class="blog-post full">
  <h1 class="title">{{ title }}</h1>
  <div class="metadatas">
    <span class="categories">
      {% for category in categories %}<span class="category">{{ category }}</span> {% endfor %}
    </span>&nbsp;-&nbsp;
    <span class="date">{{ page.date | dateFormat("DDD") }}</span>
  </div>
  <div class="content">
    {{ content | safe }}
  </div>
</article>


{% set latestPost = collections.posts | first %}
{% if latestPost.url != page.url %}
  <div class="latest_writing">
    {% include "latest_writing.njk" %}
  </div>
{% endif %}
