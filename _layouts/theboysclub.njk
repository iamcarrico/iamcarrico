---
layout: default
---

<article class="blog-post full">
  <h1 class="title">{{ title }}</h1>
  <div class="metadatas">
    <span class="categories">
      {% for category in categories %}<span class="category">{{ category }}</span> {% endfor %}
    </span>&nbsp;-&nbsp;
    <span class="date">{{ page.date | dateFormat("yyyy-MM-dd") }}</span>
  </div>

  {% if image %}
    <figure class="post-hero">
      <img src="{{ image }}" alt="{{ image_alt or title }}" sizes="(min-width: 48em) 748px, 100vw" eleventy:widths="400,800,1600" loading="eager" decoding="async">
      {% if image_caption %}<figcaption>{{ image_caption | safe }}</figcaption>{% endif %}
    </figure>
  {% endif %}

  <div class="content">

    {{ content | safe }}

    {% include "recipe-card.njk" %}
  </div>

</article>
