<article class="blog-post teaser">
  {% if post.data.image %}
    <a href="{{ post.url }}"><img class="teaser-image" src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy"></a>
  {% endif %}
  <h2 class="title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  <div class="metadatas">
    <span class="categories">
      {% for category in post.data.categories %}<span class="category">{{ category }}</span> {% endfor %}
    </span>&nbsp;-&nbsp;
    <span class="date">{{ post.date | dateFormat("DDD") }}</span>
  </div>
  <div class="content">
    {% if post.data.description %}
      {{ post.data.description | striptags }}
    {% else %}
      {{ post.templateContent | striptags | truncate(200) }}
    {% endif %}
  </div>
</article>
