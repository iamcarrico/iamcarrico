<header>
  <h1 class="site-name title"><a href="/"><span class="word">I. </span><span class="word">Am. </span><span class="word">Carrico.</span></a></h1>

  <div class="header-controls">
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
      <span class="icon icon-moon" aria-hidden="true">moon</span>
      <span class="icon icon-sun" aria-hidden="true">sun</span>
    </button>
    <a class="menuitem icon" role="menuitem" href="/feed.xml">rss&nbsp;feed</a>
    <button class="menu-toggle" onclick="toggleMenu()" aria-controls="nav" aria-expanded="false" aria-label="Open menu">
      <span class="icon icon-open" aria-hidden="true">menu</span>
      <span class="icon icon-close" aria-hidden="true">close</span>
    </button>
  </div>

  <nav id="nav" role="navigation">
    <div class="menubar" role="menubar">
      {% for nav in navigation %}
        {% set url = page.url | replace("index.html", "") %}
        {% if url == nav.url %}
          {% set current = 'active' %}
        {% elif (url | startsWith(nav.url)) and nav.url != '/' %}
          {% set current = 'active-trail' %}
        {% else %}
          {% set current = '' %}
        {% endif %}
        <a class="menuitem {{ current }}" role="menuitem" href="{{ nav.url }}">{{ nav.name }}</a>
      {% endfor %}

    </div>
  </nav>

</header>
